<?php
$host = "localhost";
$dbname = "db_keuangan_pribadi";
$username = "root"; // Sesuaikan dengan user yang kamu buat
$password = ""; // Sesuaikan dengan password kamu

try {
    // Kita gunakan PDO agar lebih aman dan terlihat profesional
    $pdo = new PDO("mysql:host=$host;dbname=$dbname", $username, $password);
    
    // Set error mode ke exception untuk mempermudah debugging
    $pdo->setAttribute(PDO::ATTR_ERRMODE, PDO::ERRMODE_EXCEPTION);
    
} catch(PDOException $e) {
    die("Koneksi gagal: " . $e->getMessage());
}
?>
